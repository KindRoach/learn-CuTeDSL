{
    "name": "learn-CuTeDSL Dev Container",
    "build": {
        "dockerfile": "./Dockerfile"
    },
    "runArgs": [
        "--runtime=nvidia",
        "--gpus=all"
    ],
    "remoteUser": "ubuntu",
    "updateRemoteUserUID": true,
    "initializeCommand": "mkdir -p ${localEnv:HOME}/.vscode-server-devcontainers",
    "mounts": [
        "source=${localEnv:HOME}/.vscode-server-devcontainers,target=/home/ubuntu/.vscode-server,type=bind"
    ]
}
